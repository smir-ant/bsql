# Build artifacts
/target

# Editor swap files
*.swp
*.swo

# macOS Finder metadata
.DS_Store

# Claude Code session data
.claude/

# SQLite benchmark database (generated by bench/setup/sqlite_setup.sql)
bench.db

# Sort enum registry (generated at compile time by #[bsql::sort])
# Each enum writes its SQL fragments here for query! to validate.
# Regenerated on every build — not source-controlled.
.bsql/sorts/

# Examples crate has its own standalone cache that gets regenerated
# whenever someone runs `cargo run --bin <example>` locally. Not worth
# committing — the examples each validate against whatever DB the user
# has BSQL_DATABASE_URL pointed at.
examples/.bsql/

